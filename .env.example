PORT=8080

# Leave empty to use coding-agent LLM for formatting/sanitization.
LLM_OPENAI_BASE_URL=
LLM_OPENAI_MODEL=
LLM_OPENAI_API_KEY=

CODING_AGENT_NAME=opencode
# Optional. Leave empty to let opencode select a default model.
CODING_AGENT_PROVIDER=
CODING_AGENT_MODEL=

GITHUB_WEBHOOK_SECRET=<required-for-server-webhook>
GITHUB_APP_ID=<required-for-server-webhook>
GITHUB_APP_PRIVATE_KEY=<required-for-server-webhook>
GITHUB_API_BASE_URL=https://api.github.com

OVERVIEW_ENABLED=false

REVIEW_SUGGESTED_CHANGES_ENABLED=false
REVIEW_SUGGESTED_CHANGES_MIN_SEVERITY=MAJOR
REVIEW_SUGGESTED_CHANGES_MAX_CANDIDATES=50
REVIEW_SUGGESTED_CHANGES_MAX_GROUP_SIZE=5
REVIEW_SUGGESTED_CHANGES_MAX_WORKERS=3
REVIEW_SUGGESTED_CHANGES_GROUP_TIMEOUT_MS=20000
REVIEW_SUGGESTED_CHANGES_GENERATE_TIMEOUT_MS=30000

REPLYCOMMENT_TRIGGER_NAME=autogitbot
